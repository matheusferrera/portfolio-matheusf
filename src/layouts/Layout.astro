---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";
import LanguageSelector from "../components/LanguageSelector.astro";
import { translations } from "../i18n/translations";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Matheus Ferreira | Desenvolvedor Full-stack",
	description = "Matheus Ferreira é um desenvolvedor full-stack focado na criação de experiências digitais acessíveis e inclusivas para a web.",
} = Astro.props;
---

<!doctype html>
<html lang="pt" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- Open Graph / Social Preview -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/og-image.svg" />
		<meta property="og:image:alt" content={title} />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="/og-image.svg" />

		<!-- JSON-LD (optional) -->
		<script type="application/ld+json">
			{`{
				"@context": "https://schema.org",
				"@type": "Person",
				"name": "Matheus Ferreira",
				"url": "/",
				"description": "${description}"
			}`}
		</script>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>

		<script is:inline>
			const theme = (() => {
				if (
					typeof localStorage !== "undefined" &&
					localStorage.getItem("theme")
				) {
					return localStorage.getItem("theme");
				}
				return "dark";
			})();

			if (theme === "light") {
				document.documentElement.classList.add("light");
			} else {
				document.documentElement.classList.remove("light");
			}
		</script>
	</head>
	<body
		class="bg-bg-navy leading-relaxed text-slate-custom antialiased selection:bg-teal-custom/30 selection:text-teal-custom"
	>
		{/* Unified Top Controls (Mobile ONLY) */}
		<div
			class="fixed top-0 right-0 z-[60] flex h-[64px] items-center gap-4 px-6 md:px-12 pointer-events-none lg:hidden"
		>
			<div class="pointer-events-auto flex items-center gap-4">
				<LanguageSelector />
				<ThemeToggle />
			</div>
		</div>

		<!-- Background Blobs -->
		<div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
			<div
				id="blob-1"
				class="fixed -left-40 -top-40 h-[800px] w-[800px] rounded-full bg-teal-custom/10 blur-[150px]"
			>
			</div>
			<div
				id="blob-2"
				class="fixed -right-20 top-1/4 h-[700px] w-[700px] rounded-full bg-blue-600/10 blur-[130px]"
			>
			</div>
			<div
				id="blob-3"
				class="fixed left-1/4 bottom-1/4 h-[800px] w-[800px] rounded-full bg-indigo-600/8 blur-[160px]"
			>
			</div>
		</div>

		<!-- Spotlight Effect -->
		<div
			id="spotlight"
			class="pointer-events-none fixed inset-0 z-30 transition duration-300"
			style="background: radial-gradient(600px at 0px 0px, var(--spotlight-color), transparent 80%);"
		>
		</div>

		<div
			class="mx-auto min-h-screen max-w-screen-xl px-6 py-12 font-sans md:px-12 md:py-20 lg:px-24 lg:py-0"
		>
			<div class="lg:flex lg:justify-between lg:gap-4">
				<slot />
			</div>
		</div>

		<script is:inline define:vars={{ translations }}>
			// Pass translations to window so the module script can access it
			window.translations = translations;
		</script>

		<script>
			import Lenis from "lenis";
			import { animate, scroll } from "motion";

			// --- i18n Logic ---
			function updateContent(lang: string) {
				const translations = (window as any).translations;
				if (!translations) return;

				document.querySelectorAll("[data-i18n]").forEach((el) => {
					const key = el.getAttribute("data-i18n");
					if (key && translations[lang] && translations[lang][key]) {
						if (key.includes("about") || key.includes("footer")) {
							el.innerHTML = translations[lang][key];
						} else {
							el.textContent = translations[lang][key];
						}
					}
				});

				document.title =
					lang === "pt"
						? "Matheus Ferreira | Desenvolvedor Full-stack"
						: lang === "en"
							? "Matheus Ferreira | Full-stack Developer"
							: "Matheus Ferreira | Desarrollador Full-stack";
			}

			window.addEventListener("language-changed", (e: any) => {
				updateContent(e.detail.lang);
			});

			// Initial load
			const savedLang = localStorage.getItem("language") || "pt";
			updateContent(savedLang);

			// --- Smooth Scroll & Animations ---
			const lenis = new Lenis({
				duration: 1.2,
				easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
				touchMultiplier: 2,
			});

			function raf(time: number) {
				lenis.raf(time);
				requestAnimationFrame(raf);
			}

			requestAnimationFrame(raf);

			const spotlight = document.getElementById("spotlight");

			window.addEventListener("mousemove", (e) => {
				if (spotlight) {
					const spotlightColor = getComputedStyle(
						document.documentElement,
					).getPropertyValue("--spotlight-color");
					spotlight.style.background = `radial-gradient(600px at ${e.clientX}px ${e.clientY}px, ${spotlightColor}, transparent 80%)`;
				}
			});

			scroll(
				animate("#blob-1", {
					y: [0, 200],
					x: [0, 100],
					opacity: [0.3, 0.6, 0.3],
				}),
			);
			scroll(
				animate("#blob-2", {
					y: [0, -300],
					x: [0, -150],
					opacity: [0.2, 0.5, 0.2],
				}),
			);
			scroll(
				animate("#blob-3", {
					y: [200, -200],
					x: [-100, 100],
					opacity: [0.2, 0.4, 0.2],
				}),
			);
		</script>
	</body>
</html>
