---
const stackCategories = [
  {
    title: "Frontend",
    tech: [
      "React",
      "Next.js",
      "Vue.js",
      "Svelte",
      "Angular",
      "AngularJS",
      "JavaScript",
      "TypeScript",
      "HTML",
      "CSS",
      "Tailwind CSS",
      "Bootstrap",
      "Figma",
    ],
  },
  {
    title: "Backend",
    tech: [
      "Node.js",
      "Express",
      "NestJS",
      "Fastify",
      "Java",
      "Spring Boot",
      "PHP",
      "APIs (REST/GraphQL)",
    ],
  },
  {
    title: "Banco de Dados",
    tech: ["Postgres SQL", "MySQL", "MongoDB", "Firebase", "Oracle DB"],
  },
  {
    title: "Infra & Ferramentas",
    tech: [
      "AWS (S3, EC2)",
      "GCP",
      "Azure",
      "Docker",
      "Kubernetes",
      "Vercel",
      "Git",
      "ZOs (Mainframe)",
      "IWS",
      "Teams Integration",
    ],
  },
];
---

<section
  id="stacks"
  class="mb-16 scroll-mt-16 md:mb-24 lg:mb-36 lg:scroll-mt-24"
  aria-label="Tecnologias e Stacks"
>
  <div
    class="sticky top-0 z-20 -mx-6 mb-4 w-screen bg-bg-navy/75 px-6 py-5 backdrop-blur md:-mx-12 md:px-12 lg:sr-only lg:relative lg:top-auto lg:mx-auto lg:w-full lg:px-0 lg:py-0 lg:opacity-0"
  >
    <h2
      class="text-sm font-bold uppercase tracking-widest text-lightest-slate lg:sr-only"
      data-i18n="nav.stacks"
    >
      Stacks
    </h2>
  </div>
  <div>
    <div class="space-y-8">
      {
        stackCategories.map((category) => (
          <div>
            <h3
              class="text-lightest-slate font-medium mb-4 text-sm uppercase tracking-widest"
              data-i18n={
                category.title === "Banco de Dados"
                  ? "stacks.db"
                  : category.title === "Infra & Ferramentas"
                    ? "stacks.infra"
                    : ""
              }
            >
              {category.title}
            </h3>
            <ul
              class="flex flex-wrap gap-2"
              aria-label={`Tecnologias de ${category.title}`}
            >
              {category.tech.map((t) => (
                <li class="flex items-center rounded-full bg-teal-custom/10 px-3 py-1 text-xs font-medium leading-5 text-teal-custom">
                  {t}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
