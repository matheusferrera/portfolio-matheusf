---
import ThemeToggle from "./ThemeToggle.astro";
import LanguageSelector from "./LanguageSelector.astro";

const socials = [
  { name: "GitHub", url: "https://github.com/matheusferrera", icon: "github" },
  { name: "Whatsapp", url: "https://wa.me/5561982501719", icon: "whatsapp" },
  {
    name: "Instagram",
    url: "https://instagram.com/matheus.ferris",
    icon: "instagram",
  },
];
---

<header
  class="pt-12 lg:sticky lg:top-0 lg:flex lg:max-h-screen lg:w-1/2 lg:flex-col lg:justify-between lg:py-24"
>
  <div style="border">
    <h1
      class="text-4xl font-bold tracking-tight text-lightest-slate sm:text-5xl"
    >
      <a href="/">Matheus Ferreira</a>
    </h1>
    <h2
      class="mt-3 text-lg font-medium tracking-tight text-lightest-slate sm:text-xl"
      data-i18n="header.role"
    >
      Desenvolvedor Full-stack
    </h2>
    <p class="mt-4 max-w-xs leading-normal" data-i18n="header.tagline">
      Eu construo experiências digitais acessíveis e inclusivas e produtos para
      a web.
    </p>

    <div class="mt-12 hidden lg:flex items-center justify-start gap-4 max-w-xs">
      <LanguageSelector />
      <ThemeToggle />
    </div>

    <nav class="nav hidden lg:block" aria-label="In-page jump links">
      <ul class="mt-16 w-max">
        <li>
          <a class="group flex items-center py-3" href="#about">
            <span
              class="nav-indicator mr-4 h-px w-8 bg-slate-custom transition-all group-hover:w-16 group-focus-visible:w-16 group-hover:bg-lightest-slate group-focus-visible:bg-lightest-slate motion-reduce:transition-none"
            ></span>
            <span
              class="nav-text text-xs font-bold uppercase tracking-widest text-slate-custom group-hover:text-lightest-slate group-focus-visible:text-lightest-slate"
              data-i18n="nav.about">Sobre</span
            >
          </a>
        </li>
        <li>
          <a class="group flex items-center py-3" href="#experience">
            <span
              class="nav-indicator mr-4 h-px w-8 bg-slate-custom transition-all group-hover:w-16 group-focus-visible:w-16 group-hover:bg-lightest-slate group-focus-visible:bg-lightest-slate motion-reduce:transition-none"
            ></span>
            <span
              class="nav-text text-xs font-bold uppercase tracking-widest text-slate-custom group-hover:text-lightest-slate group-focus-visible:text-lightest-slate"
              data-i18n="nav.experience">Experiência</span
            >
          </a>
        </li>
        <li>
          <a class="group flex items-center py-3" href="#education">
            <span
              class="nav-indicator mr-4 h-px w-8 bg-slate-custom transition-all group-hover:w-16 group-focus-visible:w-16 group-hover:bg-lightest-slate group-focus-visible:bg-lightest-slate motion-reduce:transition-none"
            ></span>
            <span
              class="nav-text text-xs font-bold uppercase tracking-widest text-slate-custom group-hover:text-lightest-slate group-focus-visible:text-lightest-slate"
              data-i18n="nav.education">Educação</span
            >
          </a>
        </li>
        <li>
          <a class="group flex items-center py-3" href="#stacks">
            <span
              class="nav-indicator mr-4 h-px w-8 bg-slate-custom transition-all group-hover:w-16 group-focus-visible:w-16 group-hover:bg-lightest-slate group-focus-visible:bg-lightest-slate motion-reduce:transition-none"
            ></span>
            <span
              class="nav-text text-xs font-bold uppercase tracking-widest text-slate-custom group-hover:text-lightest-slate group-focus-visible:text-lightest-slate"
              data-i18n="nav.stacks">Stacks</span
            >
          </a>
        </li>
      </ul>
    </nav>
  </div>

  <ul class="ml-1 mt-8 flex items-center" aria-label="Social media">
    {
      socials.map((social) => (
        <li class="mr-5 text-xs">
          <a
            class="block hover:text-lightest-slate"
            href={social.url}
            target="_blank"
            rel="noreferrer"
          >
            <span class="sr-only">{social.name}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-6 w-6"
