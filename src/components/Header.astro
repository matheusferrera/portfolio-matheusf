---
import ThemeToggle from "./ThemeToggle.astro";
import LanguageSelector from "./LanguageSelector.astro";

const socials = [
  { name: "GitHub", url: "https://github.com/matheusferrera", icon: "github" },
  { name: "Whatsapp", url: "https://wa.me/5561982501719", icon: "whatsapp" },
  {
    name: "Instagram",
    url: "https://instagram.com/matheus.ferris",
    icon: "instagram",
  },
];
---

<header
  class="pt-12 lg:sticky lg:top-0 lg:flex lg:max-h-screen lg:w-1/2 lg:flex-col lg:justify-between lg:py-24"
>
  <div style="border">
    <h1
      class="text-4xl font-bold tracking-tight text-lightest-slate sm:text-5xl"
    >
      <a href="/">Matheus Ferreira</a>
    </h1>
    <h2
      class="mt-3 text-lg font-medium tracking-tight text-lightest-slate sm:text-xl"
      data-i18n="header.role"
    >
      Desenvolvedor Full-stack
    </h2>
    <p class="mt-4 max-w-xs leading-normal" data-i18n="header.tagline">
      Eu construo experiências digitais acessíveis e inclusivas e produtos para
      a web.
    </p>
    <a
      href="http://lattes.cnpq.br/5806390345134173"
      target="_blank"
      rel="noreferrer"
      class="group mt-6 inline-flex items-center gap-2 rounded-full border border-teal-custom/50 px-4 py-2 text-xs font-semibold uppercase tracking-widest text-teal-custom transition-all hover:bg-teal-custom/10 hover:border-teal-custom hover:shadow-[0_0_15px_rgba(100,255,218,0.2)] focus-visible:bg-teal-custom/10 focus-visible:border-teal-custom"
      data-i18n="header.cv"
    >
      Currículo Lattes
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
        class="h-3 w-3 transition-transform group-hover:-translate-y-1 group-hover:translate-x-1"
      >
        <path
          fill-rule="evenodd"
          d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z"
          clip-rule="evenodd"></path>
      </svg>
    </a>

    <div class="mt-12 hidden lg:flex items-center justify-start gap-4 max-w-xs">
      <LanguageSelector />
      <ThemeToggle />
    </div>

    <nav class="nav hidden lg:block" aria-label="In-page jump links">
      <ul class="mt-16 w-max">
        <li>
          <a class="group flex items-center py-3" href="#about">
            <span
              class="nav-indicator mr-4 h-px w-8 bg-slate-custom transition-all group-hover:w-16 group-focus-visible:w-16 group-hover:bg-lightest-slate group-focus-visible:bg-lightest-slate motion-reduce:transition-none"
            ></span>
            <span
              class="nav-text text-xs font-bold uppercase tracking-widest text-slate-custom group-hover:text-lightest-slate group-focus-visible:text-lightest-slate"
              data-i18n="nav.about">Sobre</span
            >
          </a>
        </li>
        <li>
          <a class="group flex items-center py-3" href="#experience">
            <span
              class="nav-indicator mr-4 h-px w-8 bg-slate-custom transition-all group-hover:w-16 group-focus-visible:w-16 group-hover:bg-lightest-slate group-focus-visible:bg-lightest-slate motion-reduce:transition-none"
            ></span>
            <span
              class="nav-text text-xs font-bold uppercase tracking-widest text-slate-custom group-hover:text-lightest-slate group-focus-visible:text-lightest-slate"
              data-i18n="nav.experience">Experiência</span
            >
          </a>
        </li>
        <li>
          <a class="group flex items-center py-3" href="#education">
            <span
              class="nav-indicator mr-4 h-px w-8 bg-slate-custom transition-all group-hover:w-16 group-focus-visible:w-16 group-hover:bg-lightest-slate group-focus-visible:bg-lightest-slate motion-reduce:transition-none"
            ></span>
            <span
              class="nav-text text-xs font-bold uppercase tracking-widest text-slate-custom group-hover:text-lightest-slate group-focus-visible:text-lightest-slate"
              data-i18n="nav.education">Educação</span
            >
          </a>
        </li>
        <li>
          <a class="group flex items-center py-3" href="#stacks">
            <span
              class="nav-indicator mr-4 h-px w-8 bg-slate-custom transition-all group-hover:w-16 group-focus-visible:w-16 group-hover:bg-lightest-slate group-focus-visible:bg-lightest-slate motion-reduce:transition-none"
            ></span>
            <span
              class="nav-text text-xs font-bold uppercase tracking-widest text-slate-custom group-hover:text-lightest-slate group-focus-visible:text-lightest-slate"
              data-i18n="nav.stacks">Stacks</span
            >
          </a>
        </li>
      </ul>
    </nav>
  </div>

  <ul class="ml-1 mt-8 flex items-center" aria-label="Social media">
    {
      socials.map((social) => (
        <li class="mr-5 text-xs">
          <a
            class="block hover:text-lightest-slate"
            href={social.url}
            target="_blank"
            rel="noreferrer"
          >
            <span class="sr-only">{social.name}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-6 w-6"
              aria-hidden="true"
            >
              {social.name === "GitHub" && (
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
              )}
              {social.name === "LinkedIn" && (
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
              )}
              {social.name === "Instagram" && (
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm4.846-10.427c0 .795.645 1.44 1.44 1.44s1.44-.645 1.44-1.44-.645-1.44-1.44-1.44-1.44.645-1.44 1.44z" />
              )}
              {social.name === "Whatsapp" && (
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.272-.099-.47-.148-.669.15-.198.297-.768.967-.941 1.165-.173.198-.347.223-.645.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" />
              )}
            </svg>
          </a>
        </li>
      ))
    }
  </ul>
</header>

<script>
  const navLinks = document.querySelectorAll(".nav a");
  const sections = document.querySelectorAll("section[id]");

  // Initialize with the first section active
  const initialSection = "about";
  navLinks.forEach((link) => {
    if (link.getAttribute("href") === `#${initialSection}`) {
      link.classList.add("active");
    }
  });

  const observerOptions = {
    root: null,
    rootMargin: "-20% 0% -35% 0%", // Adjust margins to ensure sections activate correctly when scrolling
    threshold: 0,
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute("id");
        navLinks.forEach((link) => {
          if (link.getAttribute("href") === `#${id}`) {
            link.classList.add("active");
          } else {
            link.classList.remove("active");
          }
        });
      }
    });
  }, observerOptions);

  sections.forEach((section) => {
    observer.observe(section);
  });
</script>

<style>
  .nav-indicator {
    height: 1px;
  }

  .active .nav-indicator {
    width: 64px;
    background-color: var(--color-teal-custom) !important;
  }

  .active .nav-text {
    color: var(--color-teal-custom) !important;
  }
</style>
