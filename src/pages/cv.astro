<!doctype html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Matheus Ferreira — Currículo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      /* ===== DESIGN TOKENS — mirrors the portfolio ===== */
      :root {
        --bg-navy: #0a192f;
        --bg-navy-light: #112240;
        --bg-navy-lightest: #233554;
        --slate: #8892b0;
        --light-slate: #a8b2d1;
        --lightest-slate: #ccd6f6;
        --white-custom: #e6f1ff;
        --teal: #64ffda;
        --teal-dim: rgba(100, 255, 218, 0.1);
        --teal-border: rgba(100, 255, 218, 0.25);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
      }

      body {
        font-family: "Inter", -apple-system, system-ui, sans-serif;
        background: var(--bg-navy);
        color: var(--slate);
        line-height: 1.6;
        font-size: 11px;
        min-height: 100vh;
      }

      /* ===== PAGE LAYOUT ===== */
      .cv-page {
        max-width: 210mm;
        margin: 0 auto;
        padding: 40px 48px;
        position: relative;
        overflow: hidden;
      }

      /* Decorative side accent */
      .cv-page::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        background: linear-gradient(180deg, var(--teal) 0%, rgba(100, 255, 218, 0.1) 100%);
      }

      /* Decorative corner */
      .cv-page::after {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        width: 200px;
        height: 200px;
        background: radial-gradient(circle at 100% 0%, rgba(100, 255, 218, 0.06) 0%, transparent 70%);
        pointer-events: none;
      }

      /* ===== HEADER ===== */
      .cv-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 28px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--bg-navy-lightest);
        position: relative;
      }

      .cv-header::after {
        content: "";
        position: absolute;
        bottom: -1px;
        left: 0;
        width: 80px;
        height: 2px;
        background: var(--teal);
      }

      .cv-name {
        font-size: 32px;
        font-weight: 700;
        color: var(--lightest-slate);
        letter-spacing: -0.5px;
        line-height: 1.1;
      }

      .cv-role {
        font-size: 15px;
        font-weight: 500;
        color: var(--teal);
        margin-top: 4px;
        letter-spacing: 0.5px;
      }

      .cv-tagline {
        font-size: 11px;
        color: var(--slate);
        margin-top: 6px;
        max-width: 300px;
      }

      .cv-contacts {
        text-align: right;
        font-size: 10px;
        color: var(--light-slate);
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .cv-contacts a {
        color: var(--light-slate);
        text-decoration: none;
        transition: color 0.2s;
      }

      .cv-contacts a:hover {
        color: var(--teal);
      }

      .cv-contact-item {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 6px;
      }

      .cv-contact-icon {
        width: 12px;
        height: 12px;
        fill: var(--teal);
        flex-shrink: 0;
      }

      /* ===== TWO COLUMN LAYOUT ===== */
      .cv-body {
        display: grid;
        grid-template-columns: 1fr 220px;
        gap: 32px;
      }

      /* ===== SECTION TITLES ===== */
      .section-title {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2.5px;
        color: var(--teal);
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .section-title::after {
        content: "";
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, var(--bg-navy-lightest) 0%, transparent 100%);
      }

      /* ===== ABOUT ===== */
      .about-text {
        font-size: 10.5px;
        line-height: 1.7;
        color: var(--slate);
        margin-bottom: 24px;
      }

      .about-text strong {
        color: var(--lightest-slate);
        font-weight: 500;
      }

      /* ===== EXPERIENCE ===== */
      .exp-item {
        margin-bottom: 18px;
        padding-left: 14px;
        border-left: 2px solid var(--bg-navy-lightest);
        position: relative;
        transition: border-color 0.3s;
      }

      .exp-item:hover {
        border-left-color: var(--teal);
      }

      .exp-item::before {
        content: "";
        position: absolute;
        left: -5px;
        top: 6px;
        width: 8px;
        height: 8px;
        background: var(--bg-navy);
        border: 2px solid var(--teal);
        border-radius: 50%;
      }

      .exp-date {
        font-size: 9px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--slate);
        margin-bottom: 2px;
      }

      .exp-title {
        font-size: 12px;
        font-weight: 600;
        color: var(--lightest-slate);
        line-height: 1.3;
      }

      .exp-company {
        color: var(--teal);
        font-weight: 500;
      }

      .exp-desc {
        font-size: 10px;
        line-height: 1.6;
        color: var(--slate);
        margin-top: 4px;
      }

      .exp-tech {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-top: 6px;
        list-style: none;
      }

      .exp-tech li {
        background: var(--teal-dim);
        color: var(--teal);
        padding: 2px 8px;
        border-radius: 9999px;
        font-size: 8.5px;
        font-weight: 500;
        letter-spacing: 0.3px;
      }

      /* ===== SIDEBAR ===== */
      .sidebar-section {
        margin-bottom: 24px;
      }

      /* ===== EDUCATION ===== */
      .edu-item {
        margin-bottom: 14px;
      }

      .edu-date {
        font-size: 9px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--slate);
        margin-bottom: 2px;
      }

      .edu-title {
        font-size: 11px;
        font-weight: 600;
        color: var(--lightest-slate);
        line-height: 1.3;
      }

      .edu-school {
        font-size: 10px;
        color: var(--slate);
      }

      /* ===== SPECIALIZATIONS ===== */
      .spec-list {
        list-style: none;
        padding: 0;
      }

      .spec-list li {
        font-size: 10px;
        color: var(--slate);
        padding: 3px 0;
        display: flex;
        align-items: flex-start;
        gap: 6px;
      }

      .spec-list li::before {
        content: "▹";
        color: var(--teal);
        font-size: 10px;
        line-height: 1.6;
        flex-shrink: 0;
      }

      /* ===== STACKS ===== */
      .stack-category {
        margin-bottom: 10px;
      }

      .stack-label {
        font-size: 9.5px;
        font-weight: 600;
        color: var(--lightest-slate);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 5px;
      }

      .stack-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 3px;
        list-style: none;
      }

      .stack-pills li {
        background: var(--teal-dim);
        color: var(--teal);
        padding: 2px 7px;
        border-radius: 9999px;
        font-size: 8px;
        font-weight: 500;
        letter-spacing: 0.2px;
      }

      /* ===== FOOTER ===== */
      .cv-footer {
        margin-top: 24px;
        padding-top: 16px;
        border-top: 1px solid var(--bg-navy-lightest);
        font-size: 9px;
        color: var(--slate);
        text-align: center;
        opacity: 0.7;
      }

      /* ===== PRINT BUTTON ===== */
      .print-btn {
        position: fixed;
        bottom: 24px;
        right: 24px;
        background: linear-gradient(135deg, var(--teal) 0%, #4fd1c5 100%);
        color: var(--bg-navy);
        border: none;
        padding: 14px 28px;
        border-radius: 12px;
        font-family: "Inter", sans-serif;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        box-shadow:
          0 8px 32px rgba(100, 255, 218, 0.3),
          0 0 0 1px rgba(100, 255, 218, 0.2);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 100;
        letter-spacing: 0.5px;
      }

      .print-btn:hover {
        transform: translateY(-2px);
        box-shadow:
          0 12px 40px rgba(100, 255, 218, 0.4),
          0 0 0 1px rgba(100, 255, 218, 0.3);
      }

      .print-btn:active {
        transform: translateY(0);
      }

      .print-btn svg {
        width: 18px;
        height: 18px;
      }

      /* Back to portfolio link */
      .back-link {
        position: fixed;
        top: 24px;
        left: 24px;
        color: var(--slate);
        text-decoration: none;
        font-size: 12px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        background: var(--bg-navy-light);
        border: 1px solid var(--bg-navy-lightest);
        border-radius: 8px;
        transition: all 0.3s;
        z-index: 100;
      }

      .back-link:hover {
        color: var(--teal);
        border-color: var(--teal);
      }

      /* ===== PRINT STYLES ===== */
      @media print {
        @page {
          size: A4;
          margin: 0;
        }

        html, body {
          background: var(--bg-navy) !important;
          -webkit-print-color-adjust: exact !important;
          print-color-adjust: exact !important;
          margin: 0 !important;
          padding: 0 !important;
          width: 100% !important;
          min-height: 100% !important;
        }

        /* Force background to bleed to edges */
        html {
          background-color: var(--bg-navy) !important;
        }

        body {
          background-color: var(--bg-navy) !important;
          box-shadow: inset 0 0 0 1000px var(--bg-navy) !important;
        }

        .cv-page {
          padding: 32px 40px;
          max-width: none;
          margin: 0;
          min-height: 100vh;
          background: var(--bg-navy) !important;
        }

        .print-btn,
        .back-link {
          display: none !important;
        }

        .exp-item:hover {
          border-left-color: var(--bg-navy-lightest);
        }
      }

      /* ===== SCREEN-ONLY ANIMATIONS ===== */
      @media screen {
        .cv-page {
          animation: fadeIn 0.6s ease-out;
        }

        @keyframes fadeIn {
          from {
            opacity: 0;
            transform: translateY(10px);
          }
          to {
            opacity: 1;
            transform: translateY(0);
          }
        }

        .exp-item {
          animation: slideIn 0.4s ease-out backwards;
        }

        @keyframes slideIn {
          from {
            opacity: 0;
            transform: translateX(-10px);
          }
          to {
            opacity: 1;
            transform: translateX(0);
          }
        }

        .exp-item:nth-child(1) { animation-delay: 0.1s; }
        .exp-item:nth-child(2) { animation-delay: 0.2s; }
        .exp-item:nth-child(3) { animation-delay: 0.3s; }
        .exp-item:nth-child(4) { animation-delay: 0.4s; }
        .exp-item:nth-child(5) { animation-delay: 0.5s; }
      }
    </style>
  </head>
