          <!-- ABOUT -->
          <section>
            <h2 class="section-title">Sobre</h2>
            <p class="about-text">
              Minha jornada na tecnologia é impulsionada pela busca constante em me tornar um
              <strong>"T-shaped professional"</strong>. Com uma base sólida vinda da
              <strong>UnB</strong> (Engenharia de Redes) e especialização em Desenvolvimento Fullstack
              pela <strong>XP Educação</strong>, foco em dominar minha especialidade técnica enquanto
              amplio minha visão em <strong>UI/UX</strong>, <strong>Product Design</strong> e
              <strong>Metodologias de Testes</strong>. Ao longo da minha carreira, tive o privilégio
              de construir soluções para instituições de peso como o <strong>BRB</strong>, o
              <strong>IBICT</strong>, o <strong>Banco do Brasil</strong> e a <strong>TELEBRÁS</strong>.
            </p>
          </section>

          <!-- EXPERIENCE -->
          <section>
            <h2 class="section-title">Experiência</h2>
            {experiences.map((exp) => (
              <div class="exp-item">
                <p class="exp-date">{exp.date}</p>
                <h3 class="exp-title">
                  {exp.title} · <span class="exp-company">{exp.company}</span>
                </h3>
                <p class="exp-desc">{exp.description}</p>
                <ul class="exp-tech">
                  {exp.tech.map((t) => (
                    <li>{t}</li>
                  ))}
                </ul>
              </div>
            ))}
          </section>
        </div>

        <!-- SIDEBAR -->
        <aside>
          <!-- EDUCATION -->
          <div class="sidebar-section">
            <h2 class="section-title">Educação</h2>

            <div class="edu-item">
              <p class="edu-date">2021 — 2023</p>
              <h3 class="edu-title">Pós Graduação — Desenvolvimento Fullstack</h3>
              <p class="edu-school">XP Educação</p>
            </div>

            <div class="edu-item">
              <p class="edu-date">2015 — 2020</p>
              <h3 class="edu-title">Graduação — Engenharia de Redes</h3>
              <p class="edu-school">UnB — Universidade de Brasília</p>
            </div>
          </div>

          <!-- SPECIALIZATIONS -->
          <div class="sidebar-section">
            <h2 class="section-title">Especializações</h2>
            <ul class="spec-list">
              <li>Bootcamp Desenvolvimento Fullstack — IGTI / XP Educação</li>
              <li>Formação Full Stack Avançada (React, Next.js, Node.js)</li>
              <li>Estudos focados em UI/UX Design e Product Development</li>
            </ul>
          </div>

          <!-- STACKS -->
          <div class="sidebar-section">
            <h2 class="section-title">Stacks</h2>
            {stackCategories.map((category) => (
              <div class="stack-category">
                <p class="stack-label">{category.title}</p>
                <ul class="stack-pills">
                  {category.tech.map((t) => (
                    <li>{t}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </aside>
      </div>

      <footer class="cv-footer">
        Projetado e desenvolvido por Matheus Ferreira · Construído com Astro e Tailwind CSS
      </footer>
    </div>

    <!-- PRINT BUTTON -->
    <button class="print-btn" onclick="window.print()">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
        <path d="M19 8H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zm-3 11H8v-5h8v5zm3-7c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-1-9H6v4h12V3z" />
      </svg>
      Gerar PDF
    </button>
  </body>
</html>
